---
import type { MarkdownHeading } from "astro";
import { useTranslations } from "@/i18n";

interface Props {
  headings: MarkdownHeading[];
}

const { headings } = Astro.props;
const t = useTranslations(Astro.currentLocale);
const toc = headings.filter((heading) => heading.depth === 2 || heading.depth === 3);
---

<nav class="sticky top-20 hidden lg:block w-64 xl:w-72 max-h-[calc(100vh-5rem)] overflow-y-auto pt-8 pb-4">
  <h2 class="text-lg font-bold mb-4 text-foreground">{t.post.tableOfContents}</h2>
  <ul class="space-y-2 text-sm text-muted-foreground">
    {toc.map((heading) => (
      <li style={{ paddingLeft: `${(heading.depth - 2) * 1}rem` }}>
        <a href={`#${heading.slug}`} class="hover:text-accent transition-colors">
          {heading.text}
        </a>
      </li>
    ))}
  </ul>
</nav>
