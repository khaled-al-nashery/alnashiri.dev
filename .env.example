# Environment Variables
# Copy this file to .env and fill in the values.
# The .env file is git-ignored and should never be committed.

# Google Search Console site verification code.
# Obtain this from Google Search Console → Settings → Ownership verification → HTML tag.
# Copy only the content string from the meta tag, e.g.:
#   <meta name="google-site-verification" content="ABC123..." />
#   → PUBLIC_GOOGLE_SITE_VERIFICATION=ABC123...
PUBLIC_GOOGLE_SITE_VERIFICATION=
